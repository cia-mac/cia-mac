# ------------------------------------------------------------------
# Starving Artist — environment variables
# In Vercel, add these under Project → Settings → Environment Variables.
# Locally, copy this file to ".env.local" and fill it in.
# ------------------------------------------------------------------

# --- Database (Vercel Postgres / Neon) ---
# When you add a Postgres store in the Vercel dashboard, these are injected
# automatically. You only set them by hand for local dev.
# POSTGRES_URL=
# POSTGRES_PRISMA_URL=
# POSTGRES_URL_NON_POOLING=
# POSTGRES_USER=
# POSTGRES_HOST=
# POSTGRES_PASSWORD=
# POSTGRES_DATABASE=

# --- Image uploads (Vercel Blob) ---
# Injected automatically when you add a Blob store in the Vercel dashboard.
# BLOB_READ_WRITE_TOKEN=

# --- Sessions: any long random string (e.g. `openssl rand -hex 32`) ---
SESSION_SECRET=change-me-to-a-long-random-string

# --- One-time DB setup endpoint protection ---
SETUP_SECRET=change-me-too

# --- First admin account (created by /api/setup) ---
ADMIN_EMAIL=ciamac.parhizi@gmail.com
ADMIN_PASSWORD=pick-a-strong-password
ADMIN_NAME=Ciamac

# --- Optional: serve the portal under a path on ciamac.com ---
# Set to "/starving-artist" if you want ciamac.com/starving-artist.
# Leave unset if you deploy on its own (sub)domain like eats.ciamac.com.
# BASE_PATH=/starving-artist
